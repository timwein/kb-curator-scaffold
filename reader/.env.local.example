# ---- KB source ----
# Path to the KB content root, resolved from the reader's cwd.
# In production (Vercel root = reader), the parent dir holds the KB.
KB_CONTENT_ROOT=../

# ---- GitHub (for rating writeback) ----
GITHUB_REPO=<your-username>/<your-kb-repo>
GITHUB_BRANCH=main
# Fine-grained PAT scoped to this repo with `contents: write`.
GITHUB_TOKEN=ghp_xxx
# Shared secret configured on the GitHub webhook. Used to verify signatures on /api/revalidate.
GITHUB_WEBHOOK_SECRET=change-me

# ---- Cloudflare Access (for API auth) ----
# Your Zero Trust team domain (the part before .cloudflareaccess.com).
CF_ACCESS_TEAM_DOMAIN=<your-team-domain>
# The Application Audience (AUD) tag from the Access application settings.
CF_ACCESS_AUD=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Dev-only bypass. DO NOT set in production.
# SKIP_ACCESS_VERIFY=true

# ---- Claude (for chat) ----
ANTHROPIC_API_KEY=sk-ant-xxx

# ---- HTTP Basic Auth (simpler alternative to Cloudflare Access) ----
# When set, middleware.ts gates all requests (except /api/revalidate, which
# has its own HMAC-based auth). Browser shows a native username/password
# prompt. Leave both blank for local dev to skip the gate.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
