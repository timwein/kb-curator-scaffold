# Copy to .env and fill in real values after running setup.py
# These are written by setup.py automatically. The file is useful as a reference
# of what gets created.

ANTHROPIC_API_KEY=sk-ant-...
GITHUB_PAT=github_pat_...

# Populated by setup.py:
ENV_ID=env_...
AGENT_ID=agent_...
AGENT_VERSION=1
SEED_FILE_IDS=interests_seed.md:file_xxx,topic_taxonomy.md:file_yyy,...
